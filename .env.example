# --- Postgres ---
POSTGRES_USER=mantys
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=mantys_kanban

# --- API ---
# Internal connection string (host = postgres service name in docker-compose)
DATABASE_URL=postgresql://mantys:change-me-strong-password@postgres:5432/mantys_kanban
PORT=3000
# Strong random secret -- generate with: openssl rand -hex 32
JWT_SECRET=change-me-jwt-secret
# CORS origin = the public web URL
WEB_URL=https://kanban.mantys.studio

# --- Web (baked at image build time -- change requires a rebuild) ---
# Public API URL the browser calls
NEXT_PUBLIC_API_URL=https://api.mantys.studio
